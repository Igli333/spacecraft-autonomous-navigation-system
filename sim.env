# ============================================================
# SYSTEM CONFIGURATION
# ============================================================

KNOWLEDGE_BASE_URI=http://knowledge-base:5001
ANALYZER_URI=http://analyzer:5003
PLANNER_URI=http://planner:5004
MONITOR_URI=http://localhost:5002

DATABASE_NAME=postgres
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_HOST=postgres
DATABASE_PORT=5432

# ============================================================
# PHYSICAL CONSTANTS & SAFETY PARAMETERS
# ============================================================

ALPHA=0.1
EPSILON_RISK=0.1
MIN_RANGE=0.1

DOCKING_AXIS_X=1.0
DOCKING_AXIS_Y=0.0
DOCKING_AXIS_Z=0.0

# Gravitational parameter (Earth by default) [m^3/s^2]
MU=3.986004418e14
# MU=1.32712440018e20 #Sun
# MU=2.2032e13 # Mercury
# MU=3.24859e14 # Venus
# MU=4.9048695e12 # Moon
# MU=4.282837e13 # Mars
# MU=1.26686534e17 # Jupiter
# MU=3.7931187e16 # Saturn
# MU=5.793939e15 # Uranus
# MU=6.836529e15 # Neptune

# ============================================================
# MISSION PHASE THRESHOLDS (meters)
# ============================================================

PHASE_FAR=50
PHASE_MID=10
PHASE_CLOSE=1

# ============================================================
# DOCKING TOLERANCES
# ============================================================

DOCK_POS_THRESHOLD=0.1
DOCK_VEL_THRESHOLD=0.01
DOCK_ATT_THRESHOLD_DEG=5
DOCK_RATE_THRESHOLD_DEG=0.5

# ============================================================
# FORCE CONTROL PARAMETERS
# ============================================================

F_MAX_FAR=20.0
F_MAX_MID=10.0
F_MAX_CLOSE=2.0
F_MAX_DOCKING=0.5

K_SAFE=5e-5

# Lyapunov gains (CLOSE/DOCKING capture)
K_R=8e-5
K_V=3e-4
K_LAT=5e-4

# PD gains per phase
KP_FAR=1e-4
KD_FAR=5e-3
KP_MID=3e-4
KD_MID=1e-2
KP_CLOSE=8e-4
KD_CLOSE=3e-2
KP_DOCKING=2e-4
KD_DOCKING=5e-2

# Desired velocity limits (m/s)
V_MAX_FAR=0.5
V_MAX_MID=0.2
V_MAX_CLOSE=0.05
V_MAX_DOCKING=0.01

# ============================================================
# TORQUE CONTROL PARAMETERS
# ============================================================

K_R_TORQUE=5.0
K_W_TORQUE=50.0
TAU_MAX=0.5
P_ABORT_THRESHOLD=0.1

# ============================================================
# SIMULATION PARAMETERS
# ============================================================

TARGET_MASS=1750.0
CHASER_MASS=500.0

TARGET_INERTIA=[[1000.0,0.0,0.0],[0.0,1000.0,0.0],[0.0,0.0,1000.0]]
CHASER_INERTIA=[[600.0,0.0,0.0],[0.0,550.0,0.0],[0.0,0.0,450.0]]

R_INIT_X=7000000.0
R_INIT_Y=0.0
R_INIT_Z=0.0

V_INIT_X=0.0
V_INIT_Y=7.546e3
V_INIT_Z=0.0

SIGMA_INIT_X=0.0
SIGMA_INIT_Y=0.0
SIGMA_INIT_Z=0.0

OMEGA_INIT_X=0.0
OMEGA_INIT_Y=0.0
OMEGA_INIT_Z=0.0

SIM_TIME_STEP_SEC=1.0
SIM_STOP_TIME_SEC=1500.0

# ============================================================
# VISUALIZATION SETTINGS
# ============================================================

VIZ_REQ_ADDR=localhost
VIZ_REQ_PORT=5556
VIZ_PUB_ADDR=localhost
VIZ_PUB_PORT=5570
CLOCK_ACCEL_FACTOR=100.0

# ============================================================
# SPICE SETTINGS
